# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supavisor session-mode pooler URI (port 5432), asyncpg driver
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Gemini
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_EVAL_MODEL=gemini-3.5-flash
GEMINI_TRANSCRIBER_MODEL=gemini-3.1-flash-live-preview
EVAL_WITH_AUDIO=false

# Analytics (optional until M5)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# App
ENVIRONMENT=development
