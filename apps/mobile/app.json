{
  "expo": {
    "name": "Veritas",
    "slug": "veritas",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "veritas",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "dev.veritas.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dev.veritas.app",
      "adaptiveIcon": {
        "backgroundColor": "#0E0F12",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E0F12",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-audio",
      [
        "@siteed/audio-studio",
        {
          "microphonePermission": "Veritas records your voice so it can transcribe and evaluate your speaking practice."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
